{
  "name": "ui-review-mcp",
  "version": "0.1.3",
  "description": "MCP server that collects UI review materials (screenshots, DOM, axe-core accessibility checks) and generates structured fix prompts for implementation AI",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "ui-review-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ui-review",
    "accessibility",
    "axe-core",
    "playwright",
    "screenshot",
    "kiro",
    "kiro-power"
  ],
  "author": "evisu-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evisu-dev/ui-review-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/evisu-dev/ui-review-mcp/issues"
  },
  "homepage": "https://github.com/evisu-dev/ui-review-mcp#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "playwright": "^1.58.2",
    "sharp": "^0.34.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
