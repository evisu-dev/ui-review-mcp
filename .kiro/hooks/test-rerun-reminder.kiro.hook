{
  "enabled": true,
  "name": "テスト再実行リマインダー",
  "description": "テストファイル編集後に、テスト実行を促すリマインダーを表示します",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/*Test.php",
      "**/*test.php"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "テストファイルが編集されました。変更内容を確認するため、テストを再実行してください。テストが失敗する場合は修正してから完了としてください。"
  }
}
